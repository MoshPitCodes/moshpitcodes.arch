#!/usr/bin/env bash

set -euo pipefail

config_file="${XDG_CONFIG_HOME:-$HOME/.config}/moshpitcodes/secrets.env"
import_ssh=true
import_gpg=true
import_git=true

usage() {
    printf 'Usage: import-secrets [--config FILE] [--ssh-only | --gpg-only | --git-only]\n' >&2
}

while (($#)); do
    case "$1" in
        --config)
            config_file="$2"
            shift 2
            ;;
        --ssh-only)
            import_gpg=false
            import_git=false
            shift
            ;;
        --gpg-only)
            import_ssh=false
            import_git=false
            shift
            ;;
        --git-only)
            import_ssh=false
            import_gpg=false
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

if [[ -f "$config_file" ]]; then
    # shellcheck source=/dev/null
    source "$config_file"
fi

copy_if_present() {
    local src="$1"
    local dst="$2"
    local mode="$3"

    if [[ -f "$src" ]]; then
        install -m "$mode" "$src" "$dst"
    fi
}

sync_ssh() {
    local source_dir="${SSH_SOURCE_DIR:-}"
    local target_dir="${SSH_TARGET_DIR:-$HOME/.ssh}"
    local keys_raw="${SSH_KEYS:-id_ed25519_github}"
    local known_hosts_raw="${SSH_KNOWN_HOSTS_FILES:-known_hosts known_hosts.old allowed_signers}"
    local key
    local file

    if [[ -z "$source_dir" || ! -d "$source_dir" ]]; then
        return 0
    fi

    install -d -m 0700 "$target_dir"

    read -r -a ssh_keys <<< "$keys_raw"
    for key in "${ssh_keys[@]}"; do
        copy_if_present "$source_dir/$key" "$target_dir/$key" 0600
        copy_if_present "$source_dir/$key.pub" "$target_dir/$key.pub" 0644
    done

    read -r -a known_host_files <<< "$known_hosts_raw"
    for file in "${known_host_files[@]}"; do
        copy_if_present "$source_dir/$file" "$target_dir/$file" 0644
    done
}

sync_gpg() {
    local source_dir="${GPG_SOURCE_DIR:-}"
    local target_dir="${GPG_TARGET_DIR:-$HOME/.gnupg}"
    local file

    if [[ -z "$source_dir" || ! -d "$source_dir" ]]; then
        return 0
    fi

    gpgconf --kill all 2>/dev/null || true
    install -d -m 0700 "$target_dir"

    while IFS= read -r -d '' file; do
        case "$(basename "$file")" in
            gpg-agent.conf)
                continue
                ;;
        esac

        if [[ -d "$file" ]]; then
            install -d -m 0700 "$target_dir/${file#"$source_dir"/}"
        elif [[ -f "$file" ]]; then
            install -D -m 0600 "$file" "$target_dir/${file#"$source_dir"/}"
        fi
    done < <(find "$source_dir" -mindepth 1 -print0)

    find "$target_dir" -type f \( -name '*.lock' -o -name 'S.gpg-agent*' -o -name 'S.keyboxd' -o -name 'S.dirmngr' -o -name '.#lk*' \) -delete 2>/dev/null || true
    find "$target_dir" -type d -exec chmod 700 {} \;
    find "$target_dir" -type f -exec chmod 600 {} \;

    gpgconf --launch gpg-agent 2>/dev/null || true
}

sync_git_identity() {
    local target_file="${GITCONFIG_LOCAL_TARGET:-$HOME/.gitconfig.local}"
    local user_name="${GIT_USER_NAME:-}"
    local user_email="${GIT_USER_EMAIL:-}"

    if [[ -z "$user_name" || -z "$user_email" ]]; then
        return 0
    fi

    install -d -m 0700 "$(dirname "$target_file")"
    cat > "$target_file" <<EOF
[user]
    name = $user_name
    email = $user_email
EOF
    chmod 600 "$target_file"
}

if [[ "$import_ssh" == true ]]; then
    sync_ssh
fi

if [[ "$import_gpg" == true ]]; then
    sync_gpg
fi

if [[ "$import_git" == true ]]; then
    sync_git_identity
fi
