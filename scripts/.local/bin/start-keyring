#!/usr/bin/env bash
set -euo pipefail

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP SSH_AUTH_SOCK >/dev/null 2>&1 || true
fi

if ! pgrep -x gnome-keyring-daemon >/dev/null 2>&1; then
    gnome-keyring-daemon --start --components=secrets,ssh >/dev/null 2>&1 || true
fi
